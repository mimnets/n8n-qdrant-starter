# WARNING: The default values below are placeholders.
# You MUST replace them before starting the stack, or n8n will fail to run.
# Run ./scripts/setup.sh to generate secure values automatically.

# Database Configuration
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_to_secure_password
POSTGRES_DB=n8n

# n8n Security — generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change_me_to_random_64_hex_chars
N8N_USER_MANAGEMENT_JWT_SECRET=change_me_to_random_64_hex_chars

# Disable secure cookie for local HTTP access (remove in production with TLS)
N8N_SECURE_COOKIE=false

# =========================================================================
# Browser Use — LLM Providers (at least one required)
# The LLM is the AI that "sees" web pages and decides what to click/type.
# =========================================================================

# Default provider for browser-api (optional — overridden per request)
DEFAULT_AI_PROVIDER=openai

# DeepSeek (budget-friendly — use deepseek-reasoner for better function calling)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_ENDPOINT=https://api.deepseek.com
DEEPSEEK_MODEL_ID=deepseek-chat

# OpenAI (best reliability — gpt-4o works flawlessly with browser-use)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_ID=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ENDPOINT=https://api.openai.com/v1

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL_ID=claude-sonnet-4-6
ANTHROPIC_ENDPOINT=https://api.anthropic.com

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL_ID=gemini-2.0-flash

# Mistral
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL_ID=mistral-large-latest
MISTRAL_ENDPOINT=https://api.mistral.ai/v1

# Ollama (local LLM — no API key needed)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL_ID=llama3

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# =========================================================================
# Browser Use — Runtime Configuration
# =========================================================================

# Browser resolution (format: WIDTHxHEIGHTxDEPTH)
BROWSER_RESOLUTION=1920x1080x24
BROWSER_RESOLUTION_WIDTH=1920
BROWSER_RESOLUTION_HEIGHT=1080

# VNC password for noVNC live view at http://localhost:6080/vnc.html
VNC_PASSWORD=vncpassword

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =========================================================================
# Stealth Browser — optional configuration
# (Separate service for LinkedIn/Facebook automation)
# =========================================================================

# Proxy for stealth browser (optional — use residential proxies for LinkedIn/Facebook)
CHROME_PROXY=

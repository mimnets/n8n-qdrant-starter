# WARNING: The default values below are placeholders.
# You MUST replace them before starting the stack, or n8n will fail to run.
# Run ./scripts/setup.sh to generate secure values automatically.

# Database Configuration
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_to_secure_password
POSTGRES_DB=n8n

# n8n Security — generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change_me_to_random_64_hex_chars
N8N_USER_MANAGEMENT_JWT_SECRET=change_me_to_random_64_hex_chars

# Disable secure cookie for local HTTP access (remove in production with TLS)
N8N_SECURE_COOKIE=false

# =========================================================================
# Camofox Browser — optional configuration
# (Anti-detection Camoufox/Firefox browser for LinkedIn/Facebook automation)
# https://github.com/jo-inc/camofox-browser
# =========================================================================

# API key for secure access (generate with: openssl rand -hex 32)
CAMOFOX_API_KEY=

# Residential proxy for LinkedIn/Facebook (recommended)
LINKEDIN_PROXY_HOST=
LINKEDIN_PROXY_PORT=
LINKEDIN_PROXY_USER=
LINKEDIN_PROXY_PASS=

# =========================================================================
# Image Upload API — self-hosted imgbb replacement
# =========================================================================

UPLOAD_API_KEY=
UPLOAD_MAX_FILE_SIZE_MB=10

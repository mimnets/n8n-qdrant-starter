# In gstack-ecosystem-os deployment, RenderForge uses port 3001
# (port 3000 is reserved for CubeInsight frontend).
# Standalone: 3000 (default). Ecosystem: 3001.
PORT=3000
REDIS_URL=redis://localhost:6379
CHROMIUM_WS=ws://localhost:3001
STORAGE_DRIVER=local
STORAGE_PATH=./data/assets
DB_DRIVER=sqlite
SQLITE_PATH=./data/renderforge.db
AUTH_ENABLED=false
API_KEYS=

# ── VisualCore GPU Pipeline (opt-in) ──
GPU_ENABLED=false
GPU_VRAM_BUDGET=22528
GPU_SWAP_STRATEGY=queue
GPU_CONCURRENCY=1          # GPU worker concurrency (1 for single GPU to prevent OOM)

# ComfyUI (Flux image generation)
COMFYUI_HOST=localhost
COMFYUI_PORT=8188
COMFYUI_PROTOCOL=ws

# HunyuanVideo (local video generation)
HUNYUAN_HOST=localhost
HUNYUAN_PORT=8190
HUNYUAN_STEP_DISTILL=true
HUNYUAN_CPU_OFFLOAD=true

# Seedance API (remote video fallback for high-priority scenes)
SEEDANCE_API_KEY=
SEEDANCE_API_URL=
SEEDANCE_TIER=fast

# VoiceCore (Fish Speech TTS)
VOICECORE_ENABLED=false
VOICECORE_HOST=localhost
VOICECORE_PORT=8080

# ── Encoder ──
# ENCODER_CODEC=auto         # auto | libx264 | h264_nvenc | h264_videotoolbox | h264_qsv
# ENCODER_CRF=               # Override CRF value for libx264 (e.g. 18 for high quality KB)

# Quality Control
QC_ENABLED=false
QC_CLIP_THRESHOLD=0.25
QC_AESTHETIC_THRESHOLD=5.0
QC_NSFW_THRESHOLD=0.3

# ── ProfileCore (browser automation, opt-in) ──
PROFILECORE_ENABLED=false
PROFILECORE_HOST=localhost
PROFILECORE_PORT=3001
PROFILECORE_MODE=http
# PROFILECORE_CLI_PATH=  # path to ProfileCore repo (CLI mode only)

# ── CubeInsight (trend analysis, opt-in) ──
CUBEINSIGHT_ENABLED=false
CUBEINSIGHT_HOST=localhost
CUBEINSIGHT_PORT=8000
# CUBEINSIGHT_API_KEY=
